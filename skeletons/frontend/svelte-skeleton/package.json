    "prepare": "svelte-kit sync"
  },
  "devDependencies": {
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.53.4",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "svelte": "^5.53.7",
    "svelte-check": "^4.4.4",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "type": "module",
  "overrides": {
    "cookie": "0.7.2"
  }
}
