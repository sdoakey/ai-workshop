    "@sveltejs/kit": "^2.50.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.0",
    "svelte": "^5.50.0",
    "svelte-check": "^4.3.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  },
  "type": "module"
}
